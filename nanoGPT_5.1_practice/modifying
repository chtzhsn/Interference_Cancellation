# 2. 對照組：標準自回歸 (只 Input 一次 Prompt)
# ====================================================================
def run_baseline_standard_generation(model, encode, decode, prompt, max_steps=10):
    model.eval()
    target_ids = get_target_ids(encode, TARGET_WORDS)
    prob_history = {word: [] for word in TARGET_WORDS}
    
    # 新增：用來收集每一步選出的字串，供畫圖使用
    chosen_tokens_str = []

    print(f"\n{'='*90}\n【對照組：標準自回歸生成】(只 Input 一次 Prompt)\n{'='*90}")
    print(f"原始 Prompt: {prompt}")
    
    current_idx = torch.tensor(encode(prompt), dtype=torch.long, device=device).unsqueeze(0)
    full_generated_tokens = []

    for step in range(max_steps):
        with torch.no_grad():
            _, _, all_layers_logits = model(current_idx, return_all_logits=True)
        
        print(f"\n[Step {step+1}] 分析當前生成的 Token...")
        print(f"{'層數':<8} | {'Top 5 Tokens & Probabilities':<50} | {'目標詞機率 (Targets)'}")
        print("-" * 110)
        
        for layer_idx, layer_logits in enumerate(all_layers_logits):
            logits = layer_logits[:, -1, :] if layer_logits.dim() == 3 else layer_logits[-1, :].unsqueeze(0)
            probs = F.softmax(logits, dim=-1)
            top_probs, top_indices = torch.topk(probs[0], 5)
            
            top_info = []
            for p, idx in zip(top_probs, top_indices):
                token_str = decode([idx.item()]).replace('\n', ' ')
                top_info.append(f"'{token_str}': {p.item():.4f}")
                
            target_probs_str = ", ".join([f"'{k.strip()}': {probs[0, v].item():.4f}" for k, v in target_ids.items()])
            print(f"L{layer_idx+1:<5} | {', '.join(top_info):<50} | {target_probs_str}")
            
            for word, t_id in target_ids.items():
                prob_history[word].append(probs[0, t_id].item())
            
            if layer_idx == 11:
                next_token_id = top_indices[0].view(1, 1)

        next_chosen_word = decode([next_token_id.item()])
        current_idx = torch.cat((current_idx, next_token_id), dim=1)
        full_generated_tokens.append(next_token_id.item())
        chosen_tokens_str.append(next_chosen_word) # 紀錄該步決策字串
        
        print(f"\n>>> 本步輸出: '{next_chosen_word}'")

    print(f"\n[對照組結束] 完整續寫內容: {decode(full_generated_tokens)}")
    
    plot_title = "Baseline Group: Target Token Probabilities (Per Layer & Step)"
    plot_probabilities(prob_history, max_steps, len(all_layers_logits), plot_title, "baseline_plot.png", chosen_tokens_str)


